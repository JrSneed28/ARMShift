    "reg_with_flags": "0x%016x nzcv=0x%x",
    "flags_only": "nzcv=0x%x",
    "nzcv_encoding": "4-bit value (N<<3)|(Z<<2)|(C<<1)|V, printed as one hex nibble"
  },
  "seed_policy": {
    "description": [
